{
  "name": "shopsmart-erp",
  "version": "1.0.0",
  "private": true,
  "description": "ShopSmart Universal ERP — Monorepo root",
  "scripts": {
    "build":        "npm run build:api && npm run build:worker",
    "build:api":    "cd api    && npm ci && npm run build",
    "build:worker": "cd worker && npm ci && npm run build",
    "start":        "pm2-runtime start ecosystem.config.js",
    "dev:api":      "cd api    && npm run dev",
    "dev:worker":   "cd worker && npm run dev",
    "migrate":      "psql \"$DIRECT_URL\" -f db/init.sql",
    "migrate:check": "psql \"$DIRECT_URL\" -c 'SELECT current_database(), now();'"
  },
  "dependencies": {
    "pm2": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
