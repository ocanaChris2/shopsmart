{
  "name": "shopsmart-erp",
  "version": "1.0.0",
  "private": true,
  "description": "ShopSmart Universal ERP — Monorepo root",
  "scripts": {
    "build":        "bash scripts/build.sh",
    "start":        "pm2-runtime start ecosystem.config.js",
    "dev:api":      "npm run dev --prefix api",
    "dev:worker":   "npm run dev --prefix worker",
    "migrate":      "psql \"$DIRECT_URL\" -f db/init.sql",
    "migrate:check": "psql \"$DIRECT_URL\" -c 'SELECT current_database(), now();'"
  },
  "dependencies": {
    "pm2": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
