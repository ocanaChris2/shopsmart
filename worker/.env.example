# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# Same database as the REST API — worker shares the Postgres instance.
# The DB user must have CREATE SCHEMA privileges so pg-boss can run its
# migrations and create the pgboss.* tables on first boot.
DATABASE_URL=postgresql://user:password@localhost:5432/shopsmart
DB_POOL_MAX=5

# ── pg-boss polling ───────────────────────────────────────────────────────────
JOB_POLL_INTERVAL_SECONDS=5

# ── File storage (mock for now — replace with S3/GCS URL in production) ───────
STORAGE_BASE_URL=https://storage.example.com/exports

# ── Notifications (optional — SMTP or SendGrid for job completion alerts) ─────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_key
