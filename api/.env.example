# ── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────
# Render Postgres connection string (SSL is required in production)
DATABASE_URL=postgresql://user:password@localhost:5432/shopsmart
DB_POOL_MAX=5

# ── Auth ─────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_32_char_string_minimum
JWT_EXPIRES_IN=24h

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# ── Cloudflare (optional — cache purge on meta schema changes) ────────────────
# Zone ID: CF Dashboard → your domain → Overview → right sidebar
CF_ZONE_ID=your_zone_id_here
# API Token: CF Dashboard → My Profile → API Tokens → Zone:Cache Purge permission
CF_API_TOKEN=your_api_token_here
# Public URL of this API (used to construct cache purge URLs)
API_BASE_URL=https://api.yourdomain.com
